{
  "name": "logianfrage",
  "version": "2.1.5",
  "description": "Logistics inquiry email generator",
  "main": "out/main/index.js",
  "author": "taurisg",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "package": "electron-vite build && env -u ELECTRON_RUN_AS_NODE electron-builder",
    "package:arm64": "electron-vite build && env -u ELECTRON_RUN_AS_NODE electron-builder --mac --arm64",
    "package:x64": "electron-vite build && env -u ELECTRON_RUN_AS_NODE electron-builder --mac --x64",
    "package:win": "electron-vite build && env -u ELECTRON_RUN_AS_NODE electron-builder --win --x64"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@notionhq/client": "2.2.17",
    "@types/mailparser": "^3.4.6",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "extends": null,
    "appId": "com.taurisg.logianfrage",
    "productName": "LogiAnfrage",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "dmg": {
      "title": "LogiAnfrage",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "out/**/*",
      "node_modules/xlsx/**/*",
      "node_modules/pdf-parse/**/*",
      "node_modules/@notionhq/client/**/*",
      "package.json"
    ]
  }
}
